# ==============================================================================
# SETUP: LOAD LIBRARIES
# ==============================================================================
library(tidyverse)
library(caret)
library(RWeka)
library(rpart)
library(rpart.plot)
library(Rtsne)
library(FSelector)
library(lattice)
# Load Data
CreditData <- read.csv("C:/Users/haide/Documents/R_Project1/credit-g.csv", stringsAsFactors=TRUE)
# ==============================================================================
# TASK 1: DATA PRE-PROCESSING & VISUALIZATION (FIXED)
# ==============================================================================
# 1. We need to turn words into numbers for the t-SNE math
# We use 'dummyVars' to create a numeric-only version of the data
Credit_Unique <- unique(CreditData)
numeric_only_data <- dummyVars(" ~ .", data = Credit_Unique[,-21]) %>%
predict(newdata = Credit_Unique[,-21])
# 2. Now we run t-SNE on the numeric version
set.seed(42)
tsne_out <- Rtsne(as.matrix(numeric_only_data), perplexity=30, check_duplicates = FALSE)
# 3. Draw the map
plot(tsne_out$Y, col=Credit_Unique$class, pch=19,
main="Task 1: t-SNE Visualization")
legend("topright", legend=levels(Credit_Unique$class), col=1:2, pch=19)
# Feature Selection
weights <- chi.squared(class ~ ., data = CreditData)
subset_features <- cutoff.k(weights, 10)
f <- as.simple.formula(subset_features, "class")
# Data Splitting
set.seed(123)
inTrain <- createDataPartition(y = CreditData$class, p = 0.7, list = FALSE)
training_set <- CreditData[inTrain, ]
testing_set <- CreditData[-inTrain, ]
# ==============================================================================
# TASK 2: TRAINING (30 TESTS EACH)
# ==============================================================================
trctrl <- trainControl(method = "repeatedcv", number = 10, repeats = 3)
print("Training models... this takes a moment...")
set.seed(3333)
dtree_fit <- train(f, data=training_set, method = "rpart", trControl=trctrl)
set.seed(3333)
part_fit <- train(f, data = training_set, method = "PART", trControl=trctrl)
set.seed(3333)
ripper_fit <- train(f, data = training_set, method = "JRip", trControl=trctrl)
# Display Rules
print("--- Task 2 PART 2 - RULES ---")
print(dtree_fit$finalModel)
print(part_fit$finalModel)
print(ripper_fit$finalModel)
# ==============================================================================
# TASK 3: THE MATH BATTLE (ANOVA)
# ==============================================================================
# 1. Collect Accuracy Data
results <- resamples(list(DecisionTree = dtree_fit, PART = part_fit, Ripper = ripper_fit))
results_table <- results$values
# 2. Extract Accuracy Vectors (Using backticks for exact matches)
vec_dtree  <- results_table$`DecisionTree~Accuracy`
vec_part   <- results_table$`PART~Accuracy`
vec_ripper <- results_table$`Ripper~Accuracy`
# 3. Format data for ANOVA
accuracy_scr <- c(vec_dtree, vec_part, vec_ripper)
model_names <- c(rep("DecisionTree", 30), rep("PART", 30), rep("Ripper", 30))
battle_data <- data.frame(Accuracy = accuracy_scr, Model = model_names)
# 4. RUN ANOVA
anova_results <- aov(Accuracy ~ Model, data = battle_data)
# 5. PRINT RESULTS
print("--- TASK 3 PART 2: ANOVA TABLE ---")
print(summary(anova_results))
print("--- TASK 3 PART 3: TUKEY TEST ---")
print(TukeyHSD(anova_results))
# 6. VISUALIZE
# If bwplot fails, boxplot is our safety net
bwplot(results, main="Classifier Accuracy Comparison")
load("C:/Users/haide/Documents/R_Project1/.RData")
